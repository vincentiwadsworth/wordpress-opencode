{
  "name": "wordpress-opencode/site",
  "type": "project",
  "license": "MIT",
  "description": "Bedrock-based WordPress project with Elementor Pro for wordpress-opencode",
  "repositories": [
    {
      "type": "composer",
      "url": "https://wpackagist.org",
      "only": ["wpackagist-plugin/*", "wpackagist-theme/*"]
    },
    {
      "type": "composer",
      "url": "https://composer.elementor.com",
      "only": ["elementor/elementor-pro"]
    }
  ],
    "require": {
    "php": ">=8.3",
    "composer/installers": "^2.0",
    "oscarotero/env": "^2.0",
    "roots/bedrock-autoloader": "^1.0",
    "roots/bedrock-disallow-indexing": "^2.0",
    "roots/wordpress": "7.0",
    "roots/wp-config": "^1.0",
    "vlucas/phpdotenv": "^5.0",
    "wpackagist-plugin/elementor": "^3.25"
  },
  "suggest": {
    "elementor/elementor-pro": "Install Elementor Pro with your license: run 'composer require elementor/elementor-pro' after adding ELEMENTOR_PRO_LICENSE to .env and restarting DDEV"
  },
  "require-dev": {
    "laravel/pint": "^1.0",
    "pestphp/pest": "^4.0"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "allow-plugins": {
      "composer/installers": true,
      "roots/wordpress-core-installer": true,
      "pestphp/pest-plugin": true
    },
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "extra": {
    "installer-paths": {
      "web/app/mu-plugins/{$name}/": [
        "type:wordpress-muplugin"
      ],
      "web/app/plugins/{$name}/": [
        "type:wordpress-plugin"
      ],
      "web/app/themes/{$name}/": [
        "type:wordpress-theme"
      ]
    },
    "wordpress-install-dir": "web/wp"
  },
  "scripts": {
    "lint": "pint --test",
    "lint:fix": "pint",
    "test": "pest"
  }
}
